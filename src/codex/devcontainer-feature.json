{
    "name": "OpenAI Codex",
    "id": "codex",
    "version": "2.0.0",
    "description": "Install OpenAI Codex CLI via npm.",
    "mounts": [
        {
            "source": "codex-credentials",
            "target": "/opt/codex-credentials",
            "type": "volume"
        }
    ],
    "postStartCommand": "ln -sfn /opt/codex-credentials ${HOME}/.codex",
    "options": {
        "codex_version": {
            "type": "string",
            "default": "latest",
            "description": "Version of @openai/codex to install with npm."
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils",
        "ghcr.io/devcontainers/features/node"
    ]
}