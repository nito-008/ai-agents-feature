{
    "name": "OpenAI Codex",
    "id": "codex",
    "version": "1.0.0",
    "description": "Install OpenAI Codex CLI via npm.",
    "mounts": [
        {
            "source": "${localEnv:HOME}/.codex",
            "target": "${containerEnv:HOME}/.codex",
            "type": "bind"
        }
    ],
    "options": {
        "codex_version": {
            "type": "string",
            "default": "latest",
            "description": "Version of @openai/codex to install with npm."
        },
        "node_version": {
            "type": "string",
            "default": "20",
            "description": "Major Node.js version to install if node/npm are missing."
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}