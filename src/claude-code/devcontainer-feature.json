{
    "name": "Claude Code",
    "id": "claude-code",
    "version": "1.2.0",
    "description": "Install Claude Code CLI",
    "mounts": [
        {
            "source": "claude-credentials",
            "target": "/opt/claude-credentials",
            "type": "volume"
        }
    ],
    "postStartCommand": "ln -sfn /opt/claude-credentials/dot-claude ${HOME}/.claude && ln -sf /opt/claude-credentials/dot-claude.json ${HOME}/.claude.json",
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}